{
  "version": 2,
  "outputDirectory": "artifacts/codearena/dist/public",
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "artifacts/codearena/dist/public/**",
        "artifacts/api-server/dist/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
